MOCK_LLM=false

# When using docker compose, the connection to llama.cpp server must be done through host.docker.internal URL.
LLM_BASE_URL=http://host.docker.internal:8002/v1

LLM_API_KEY=local-key
LLM_MODEL=local-model

CHUNK_SIZE=900
CHUNK_OVERLAP=150

LLM_MAX_TOKENS=800
LLM_TEMPERATURE=0.2

ENABLE_RERANKER=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=20

CHROMA_COLLECTION=paperops_documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

TOP_K=5